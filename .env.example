# ============================================================
# llx Environment Configuration Example
# Copy this file to .env and fill in your API keys
# ============================================================

# --- LLM Provider API Keys ---
# Add your API keys here. Never commit this file to version control.

# Anthropic Claude (Opus, Sonnet, Haiku)
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI (GPT-4, GPT-4o, GPT-4o-mini)
OPENAI_API_KEY=sk-...

# OpenRouter (300+ models, single key) - RECOMMENDED FOR FREE TIER
OPENROUTER_API_KEY=sk-or-v1-...

# Google AI Studio (Gemini 2.5 Pro/Flash)
GOOGLE_AI_KEY=AIza...

# DeepSeek (V3, R1 - cheapest cloud)
DEEPSEEK_API_KEY=sk-...

# Groq (ultra-fast inference)
GROQ_API_KEY=gsk_...

# Together AI (open-source models)
TOGETHER_API_KEY=...

# Mistral (Codestral, Mistral Large)
MISTRAL_API_KEY=...

# --- Default Configuration ---
# These can be overridden by environment variables or command line options

# Default server configuration
LLX_DEFAULT_PORT=8000
LLX_DEFAULT_HOST=0.0.0.0
LLX_DEFAULT_URL=http://localhost:8000

# Default generation settings
LLX_DEFAULT_PROFILE=cheap
LLX_DEFAULT_SPRINTS=8
LLX_DEFAULT_FOCUS=api

# Monitoring settings
LLX_MONITOR_INTERVAL=30
LLX_AUTO_INSTALL=true

# Tool preferences
LLX_TOOL=llx
ENVIRONMENT=local
