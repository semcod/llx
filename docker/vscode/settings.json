{
  "workbench.colorTheme": "Default Dark+",
  "editor.fontSize": 14,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.wordWrap": "on",
  "editor.minimap.enabled": false,
  "editor.suggestSelection": "first",
  "editor.inlineSuggest.enabled": true,
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,
  
  // Disable GitHub Copilot completely
  "github.copilot.enable": false,
  "github.copilot.advanced.enabled": false,
  "github.copilot.inlineSuggest.enable": false,
  
  // Disable Continue.dev
  "continue.enable": false,
  
  // RooCode Configuration - Primary AI Assistant
  "roocode.enable": true,
  "roocode.autoStart": true,
  "roocode.defaultProvider": "openai-compatible",
  "roocode.model": "qwen2.5-coder:7b",
  "roocode.apiKey": "sk-proxy-local-dev",
  "roocode.apiBaseUrl": "http://localhost:4000/v1",
  "roocode.temperature": 0.2,
  "roocode.maxTokens": 4096,
  "roocode.stream": true,
  "roocode.contextLength": 32000,
  
  // RooCode Chat Settings
  "roocode.chat.enabled": true,
  "roocode.chat.position": "right",
  "roocode.chat.size": "medium",
  "roocode.chat.autoFocus": true,
  "roocode.chat.preserveHistory": true,
  
  // RooCode Inline Suggestions
  "roocode.inline.enabled": true,
  "roocode.inline.triggerMode": "automatic",
  "roocode.inline.delay": 500,
  "roocode.inline.maxSuggestions": 3,
  
  // RooCode Code Actions
  "roocode.codeActions.enabled": true,
  "roocode.codeActions.generateCode": true,
  "roocode.codeActions.refactor": true,
  "roocode.codeActions.explainCode": true,
  "roocode.codeActions.addComments": true,
  "roocode.codeActions.fixBugs": true,
  "roocode.codeActions.writeTests": true,
  
  // RooCode Shortcuts
  "roocode.shortcuts.chat": "ctrl+shift+r",
  "roocode.shortcuts.inline": "ctrl+shift+i",
  "roocode.shortcuts.explain": "ctrl+shift+e",
  "roocode.shortcuts.refactor": "ctrl+shift+f",
  
  // Alternative: Local Ollama Configuration
  "roocode.fallbackProvider": "ollama",
  "roocode.fallbackModel": "qwen2.5-coder:7b",
  "roocode.fallbackBaseUrl": "http://localhost:11434",
  
  // Disable native VS Code AI features
  "ai.chat.enabled": false,
  "ai.inlineChat.enabled": false,
  "ai.assistant.enabled": false,
  
  // Code Runner Settings
  "code-runner.runInTerminal": true,
  "code-runner.executorMap": {
    "python": "python",
    "javascript": "node",
    "typescript": "ts-node"
  },
  
  // Terminal settings
  "terminal.integrated.shell.linux": "/bin/bash",
  "terminal.integrated.fontSize": 14,
  
  // Python settings
  "python.defaultInterpreterPath": "/usr/local/bin/python",
  "python.linting.enabled": true,
  "python.linting.pylintEnabled": true,
  "python.formatting.provider": "black",
  
  // Git settings
  "git.enableSmartCommit": true,
  "git.autofetch": true,
  "git.confirmSync": false,
  "extensions.ignoreRecommendations": false,
  
  // Auto-install extensions
  "extensions.autoUpdate": false,
  "extensions.autoCheckUpdates": false
}
