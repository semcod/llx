# ============================================================
# llx Environment Configuration
# API Keys and Environment Variables Only
# Configuration moved to: llx.yaml and litellm-config.yaml
# ============================================================

# --- LLM Provider API Keys ---
# Add your API keys here. Never commit this file to version control.

# Anthropic Claude (Opus, Sonnet, Haiku)
ANTHROPIC_API_KEY=sk-ant-api03

# OpenAI (GPT-4, GPT-4o, GPT-4o-mini)
OPENAI_API_KEY=

# OpenRouter (300+ models, single key)
OPENROUTER_API_KEY=sk-or-v1-

# Google AI Studio (Gemini 2.5 Pro/Flash)
GOOGLE_AI_KEY=

# DeepSeek (V3, R1 - cheapest cloud)
DEEPSEEK_API_KEY=

# Groq (ultra-fast inference)
GROQ_API_KEY=

# Together AI (open-source models)
TOGETHER_API_KEY=

# Mistral (Codestral, Mistral Large)
MISTRAL_API_KEY=

# Fireworks AI (fast open-source inference)
FIREWORKS_API_KEY=

# Cerebras (fastest inference)
CEREBRAS_API_KEY=

# Azure OpenAI (optional)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-02-01

# --- External Service API Keys ---

# GitHub (Personal Access Token with 'repo' scope)
# Get token: https://github.com/settings/tokens
GITHUB_API_KEY=github_pat_

# GitLab (Personal/Project Access Token with 'api' or 'write_repository' scope)
# Get token: https://gitlab.com/-/profile/personal_access_tokens
GITLAB_API_KEY=
GITLAB_BASE_URL=

# Jira (API Token with 'write:issue:jira' scope + your email)
# Get token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_KEY=
JIRA_EMAIL=
JIRA_BASE_URL=https://your-domain.atlassian.net

# --- Local Model Settings ---

# Ollama (local LLM server)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_SECONDARY_URL=

# --- Cache and Storage ---

# Redis (for caching and semantic search)
REDIS_URL=redis://localhost:6379/0

# --- Network and Endpoints ---

# LiteLLM Proxy Server
LITELLM_PROXY_HOST=0.0.0.0
LITELLM_PROXY_PORT=4000
LITELLM_PROXY_MASTER_KEY=sk-proxy-local-dev

# Dashboard and Client URLs
DASHBOARD_API_URL=http://localhost:4000
DEFAULT_PROXY_URL=http://localhost:4000
DEFAULT_API_KEY=sk-proxy-local-dev

# --- Development Settings ---

# Development server port (can be different from production)
DEV_PORT=4001

# Enable debug mode
DEBUG=false

# Enable hot reload for development
HOT_RELOAD=false

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# --- Budget and Cost Controls ---

# Monthly budget cap in USD (0 = unlimited)
MONTHLY_BUDGET_USD=60

# Daily budget cap
DAILY_BUDGET_USD=5

# Per-request max cost
MAX_REQUEST_COST_USD=2.0

# --- Feature Flags ---

# Enable experimental features
LLX_EXPERIMENTAL=false

# Enable beta features
LLX_BETA=true

# Enable monitoring
LLX_MONITORING=true

# --- Security Settings ---

# Encrypt API keys at rest
LLX_ENCRYPT_KEYS=false

# Enable audit logging
LLX_AUDIT_LOG=true

# --- Integration Settings ---

# VS Code Web (for docker compose)
VSCODE_PORT=8080
VSCODE_PASSWORD=proxym-vscode
VSCODE_PROJECT_PATH=./
VSCODE_WORKSPACE_NAME=llx

# VS Code model mappings
VSCODE_MODEL_CODE=balanced
VSCODE_MODEL_ARCHITECT=free
VSCODE_MODEL_DEBUG=cheap
VSCODE_MODEL_ASK=free
VSCODE_MODEL_OPUS=premium

# Open WebUI
OPEN_WEBUI_PORT=3000

# --- Observability ---

# Watchdog settings
LLX_WATCHDOG_ENABLED=true
LLX_WATCHDOG_INTERVAL=60

# Self-healing settings
LLX_REPAIR_ENABLED=false
LLX_REPAIR_MODE=suggest
LLX_REPAIR_API_KEY=
LLX_REPAIR_MODEL=anthropic/claude-sonnet-4-20250514
LLX_REPAIR_BUDGET_DAILY=2.0

# --- Diagnostics ---

# Diagnostics proxy URL
LLX_DIAGNOSTICS_PROXY_URL=http://localhost:4000

# --- Tool Availability ---

# Force specific tools to be available (comma-separated or "*")
LLX_TOOLS_AVAILABLE=

# Examples:
# LLX_TOOLS_AVAILABLE=claude-code,vscode,cursor,windsurf,browser
# LLX_TOOLS_AVAILABLE=*
